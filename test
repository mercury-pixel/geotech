services:
  postgres:
    image: postgis/postgis:15-3.4
    container_name: geotech-postgres
    hostname: postgres
    restart: always
    ports:
      - "5434:5432"
    environment:
      POSTGRES_DB: db_geotech
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
    volumes:
      - geotech_data:/var/lib/postgresql/data
    networks:
      - geotech_network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -d db_geotech"]
      interval: 5s
      timeout: 5s
      retries: 5

